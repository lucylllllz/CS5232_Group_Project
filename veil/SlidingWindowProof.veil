veil module SlidingWindowProof

import SlidingWindow

type Char
const k: int
const s: seq<Char>

--------------------------------------------------
-- Ghost specification
--------------------------------------------------
ghost function distinct_chars(s: seq<Char>, lo: int, hi: int): set<Char>

--------------------------------------------------
-- Invariants
--------------------------------------------------
invariant 0 <= lo <= hi <= |s|
invariant d >= 0
invariant d <= k

-- Core correctness invariant
invariant d == |distinct_chars(s, lo, hi)|

--------------------------------------------------
-- Extend preserves invariant
--------------------------------------------------
theorem Extend_preserves
{
  requires hi < |s|
  ensures d == |distinct_chars(s, lo, hi)|
}
{
  -- Case split:
  -- 1. s[hi] already in set → no change
  -- 2. new char → cardinality +1
}

--------------------------------------------------
-- Shrink preserves invariant
--------------------------------------------------
theorem Shrink_preserves
{
  requires lo < hi
  ensures d == |distinct_chars(s, lo, hi)|
}
{
  -- Case split:
  -- 1. count > 1 → no change
  -- 2. count == 1 → remove element
}