veil module SlidingWindow

type Char

type State = {
  lo: int,
  hi: int,
  count: map<Char, int>,
  d: int
}

--------------------------------------------------
-- Initialization
--------------------------------------------------
after_init {
  lo := 0;
  hi := 0;
  count := map.empty;
  d := 0;
}

--------------------------------------------------
-- Extend
--------------------------------------------------
action Extend(s: seq<Char>)
requires hi < |s|
{
  if s[hi] in count {
    count[s[hi]] := count[s[hi]] + 1;
  } else {
    count[s[hi]] := 1;
    d := d + 1;
  }
  hi := hi + 1;
}

--------------------------------------------------
-- Shrink
--------------------------------------------------
action Shrink(s: seq<Char>)
requires lo < hi
{
  if count[s[lo]] > 1 {
    count[s[lo]] := count[s[lo]] - 1;
  } else {
    remove count[s[lo]];
    d := d - 1;
  }
  lo := lo + 1;
}